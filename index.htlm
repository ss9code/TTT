// ロードマップ
// ════════════════════════════════
const RM=[
  {step:'Phase 1',title:'時間補正の可視化',icon:'📊',col:'#2ecc71',
   desc:'すべての金融商品に「時間補正利益率」の表示を義務化。真の利益 = 損益 ÷ √t を標準指標に。',
   effect:'超高速取引（HFT）の見かけ上の優位性が消える',ttt:'v₃（時間）ベクトルを市場に「見える化」'},
  {step:'Phase 2',title:'モノの価値の再評価',icon:'📦',col:'#4a9eff',
   desc:'実体経済（モノ・労働・資源）の価値を v₂ベクトルとして定量化する国際基準を策定。',
   effect:'投機目的の空売り・デリバティブに実体裏付けを要求',ttt:'v₂（モノ）ベクトルを実体経済と連動'},
  {step:'Phase 3',title:'TTT均衡取引の標準化',icon:'⚖️',col:'#7c6af7',
   desc:'v₁+v₂+v₃=0 を満たす取引を「標準取引」として低税率・優遇措置を適用。均衡を崩す取引には課税。',
   effect:'市場参加者が自然にバランスある取引を選ぶ設計',ttt:'TTT均衡を市場インセンティブに組み込む'},
  {step:'Phase 4',title:'グローバル実装',icon:'🌏',col:'#f39c12',
   desc:'国際決済銀行（BIS）・IMFとの協調によりTTT標準をグローバル金融規制の基盤に。',
   effect:'金融至上主義から「三位一体の均衡」へのパラダイム転換',ttt:'正四面体の対称性が世界経済に実装される'},
];
let rmActive=0;
function buildRoadmap(){
  const el=document.getElementById('rmContainer');el.innerHTML='';
  RM.forEach((r,i)=>{
    const on=i===rmActive;
    el.innerHTML+=`<div class="rm-item" style="opacity:${on?1:.45};" onclick="rmActive=${i};buildRoadmap();">
      <div class="rm-icon" style="background:${r.col}18;border-color:${r.col};font-size:16px;">${r.icon}</div>
      <div class="rm-body" style="${on?`background:var(--sur2);border-color:${r.col}44;`:''}padding:10px 12px;">
        <div style="font-size:10px;color:${r.col};font-family:'Space Mono',monospace;margin-bottom:3px;">${r.step}</div>
        <div style="font-size:13px;font-weight:bold;margin-bottom:${on?8:0}px;">${r.title}</div>
        ${on?`<div style="font-size:11px;color:var(--muted);line-height:1.8;margin-bottom:7px;">${r.desc}</div>
        <div style="font-size:11px;color:#2ecc71;background:var(--bg);border-radius:5px;padding:5px 9px;margin-bottom:5px;">✓ ${r.effect}</div>
        <div style="font-size:10px;color:var(--acc);font-family:'Space Mono',monospace;background:var(--bg);border-radius:5px;padding:4px 9px;">TTT: ${r.ttt}</div>`:''}
      </div>
    </div>`;
  });
}
const VISION=[
  {before:'利益 = 売値 − 買値',after:'真の利益 = (売値−買値) ÷ √t',label:'計算の標準化',col:'#2ecc71'},
  {before:'お金が最も重要な価値',after:'モノ・時間・お金は等価',label:'価値観の転換',col:'#4a9eff'},
  {before:'市場は勝者総取りのゲーム',after:'市場はTTT均衡を目指す系',label:'市場哲学の転換',col:'#7c6af7'},
  {before:'時間は資本家のもの',after:'時間はすべての人に平等',label:'時間の民主化',col:'#f39c12'},
];
function buildVision(){
  document.getElementById('visionList').innerHTML=VISION.map(({before,after,label,col})=>
    `<div class="cmp-row">
      <div class="cmp-before">${before}</div>
      <div style="color:${col};font-size:16px;">→</div>
      <div class="cmp-after">${after}</div>
      <div class="cmp-label" style="color:${col};">${label}</div>
    </div>`).join('');
}

// ════════════════════════════════
// 球面調和関数 可視化
// ════════════════════════════════
function drawYlm(canvasId, l, col){
  const cv=document.getElementById(canvasId);if(!cv)return;
  const ctx=cv.getContext('2d'),W=cv.width,H=cv.height,cx=W/2,cy=H/2,R=Math.min(W,H)/2-6;
  ctx.clearRect(0,0,W,H);
  ctx.beginPath();ctx.arc(cx,cy,R,0,TAU);
  ctx.strokeStyle='rgba(255,255,255,0.06)';ctx.lineWidth=1;ctx.stroke();

  if(l===0){
    ctx.beginPath();ctx.arc(cx,cy,R*0.42,0,TAU);
    ctx.strokeStyle=col;ctx.lineWidth=2;ctx.stroke();
    ctx.beginPath();ctx.arc(cx,cy,R*0.42,0,TAU);
    ctx.fillStyle=col+'22';ctx.fill();
  } else if(l===1){
    // 双極：8の字（上下）
    ['#fff',col].forEach((c,half)=>{
      const sign=half===0?1:-1;
      ctx.beginPath();
      for(let i=0;i<=120;i++){
        const th=(i/120)*Math.PI;
        const r=Math.abs(Math.cos(th))*R*0.82;
        const x=cx+r*Math.sin(th)*sign;
        const y=cy-r*Math.cos(th);
        i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
      }
      ctx.strokeStyle=half===0?'rgba(255,255,255,0.15)':col;ctx.lineWidth=1.5;ctx.stroke();
      ctx.fillStyle=half===0?'rgba(255,255,255,0.04)':col+'28';ctx.fill();
    });
  } else if(l===2){
    // 四重極：花びら4枚
    [0,90,180,270].forEach(deg=>{
      const a=deg*DEG;
      ctx.beginPath();
      for(let i=0;i<=120;i++){
        const th=(i/120)*TAU;
        const r=Math.abs(Math.cos(2*th))*R*0.7;
        const x=cx+r*Math.cos(th+a);
        const y=cy+r*Math.sin(th+a);
        i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
      }
      ctx.strokeStyle=col;ctx.lineWidth=1.5;ctx.stroke();
      ctx.fillStyle=col+'18';ctx.fill();
    });
  } else if(l===3){
    // 八重極：梨型＋花びら6枚
    [0,60,120,180,240,300].forEach((deg,idx)=>{
      const a=deg*DEG;
      ctx.beginPath();
      for(let i=0;i<=120;i++){
        const th=(i/120)*TAU;
        const r=Math.abs(Math.cos(3*th))*R*0.65;
        const x=cx+r*Math.cos(th+a);
        const y=cy+r*Math.sin(th+a);
        i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
      }
      ctx.strokeStyle=col;ctx.lineWidth=1.5;ctx.stroke();
      ctx.fillStyle=idx%2===0?col+'20':col+'0a';ctx.fill();
    });
    // 中心リング
    ctx.beginPath();ctx.arc(cx,cy,R*0.18,0,TAU);
    ctx.strokeStyle=col+'60';ctx.lineWidth=1;ctx.stroke();
  }

  ctx.fillStyle='rgba(255,255,255,0.25)';ctx.font='9px monospace';ctx.textAlign='center';
  ctx.fillText(`l=${l}`,cx,H-4);
}

function drawAllYlm(){
  drawYlm('ylm0',0,'rgba(150,150,150,0.8)');
  drawYlm('ylm1',1,'rgba(124,106,247,0.9)');
  drawYlm('ylm2',2,'rgba(74,158,255,0.9)');
  drawYlm('ylm3',3,'rgba(230,126,34,0.9)');
}

// ════════════════════════════════
// 質量スペクトル
// ════════════════════════════════
const ZNL=[4.493409457909064,7.725251836937314,10.904121659428734,14.066193912831439,17.220755271930763];
const ZREL=ZNL.map(z=>z/ZNL[0]);
const NBARS=ZNL.length;
const BAR_COLS=['#2ecc71','#f39c12','#f39c12','rgba(150,150,150,0.7)','rgba(150,150,150,0.7)'];

function drawMassChart(){
  const cv=document.getElementById('massChart');if(!cv)return;
  const ctx=cv.getContext('2d'),W=cv.width,H=cv.height;
  ctx.clearRect(0,0,W,H);
  const pad={t:20,b:40,l:50,r:20};
  const cw=W-pad.l-pad.r, ch=H-pad.t-pad.b;
  const barW=cw/NBARS*0.6, gap=cw/NBARS;
  const maxZ=ZNL[NBARS-1]*1.1;

  // グリッド
  [0,0.25,0.5,0.75,1].forEach(r=>{
    const y=pad.t+ch*(1-r);
    ctx.beginPath();ctx.moveTo(pad.l,y);ctx.lineTo(W-pad.r,y);
    ctx.strokeStyle='rgba(255,255,255,0.04)';ctx.lineWidth=1;ctx.stroke();
    ctx.fillStyle='rgba(255,255,255,0.2)';ctx.font='9px monospace';ctx.textAlign='right';
    ctx.fillText((r*maxZ).toFixed(1),pad.l-4,y+3);
  });

  // 軸ラベル
  ctx.fillStyle='rgba(255,255,255,0.3)';ctx.font='10px monospace';ctx.textAlign='center';
  ctx.fillText('z_n1（固有値）',W/2,H-4);

  // バー
  ZNL.forEach((z,i)=>{
    const x=pad.l+gap*i+gap*0.2;
    const bh=(z/maxZ)*ch;
    const y=pad.t+ch-bh;

    // グラデーション
    const grad=ctx.createLinearGradient(x,y,x,y+bh);
    grad.addColorStop(0,BAR_COLS[i]);
    grad.addColorStop(1,BAR_COLS[i].replace(')',',0.3)').replace('rgba','rgba').replace('#','rgba(').replace(/^rgba\(([0-9a-f]{2})([0-9a-f]{2})([0-9a-f]{2})/i,(m,r,g,b)=>`rgba(${parseInt(r,16)},${parseInt(g,16)},${parseInt(b,16)}`));

    ctx.fillStyle=BAR_COLS[i];
    ctx.beginPath();
    ctx.roundRect?ctx.roundRect(x,y,barW,bh,4):ctx.rect(x,y,barW,bh);
    ctx.globalAlpha=0.85;ctx.fill();ctx.globalAlpha=1;

    // 値ラベル
    ctx.fillStyle=BAR_COLS[i];ctx.font='bold 10px monospace';ctx.textAlign='center';
    ctx.fillText(z.toFixed(3),x+barW/2,y-5);

    // n ラベル
    ctx.fillStyle='rgba(255,255,255,0.5)';ctx.font='11px sans-serif';
    ctx.fillText(`n=${i+1}`,x+barW/2,H-pad.b+14);

    // 相対質量
    ctx.fillStyle='rgba(255,255,255,0.3)';ctx.font='9px monospace';
    ctx.fillText(`×${ZREL[i].toFixed(3)}`,x+barW/2,H-pad.b+26);
  });

  // n=1 強調ライン
  const y1=pad.t+ch-(ZNL[0]/maxZ)*ch;
  ctx.beginPath();ctx.moveTo(pad.l,y1);ctx.lineTo(W-pad.r,y1);
  ctx.strokeStyle='rgba(46,204,113,0.2)';ctx.lineWidth=1;ctx.setLineDash([4,3]);ctx.stroke();ctx.setLineDash([]);
}

let currentScale='natural';
function setScale(k){
  currentScale=k;
  ['natural','electron','planck'].forEach(id=>{
    const el=document.getElementById('sc-'+id);
    if(el)el.style.opacity=id===k?'1':'0.5';
  });

  const HBAR=1.054571817e-34; // J·s
  const C=2.99792458e8;       // m/s
  const MEV=1.602176634e-13;  // J per MeV
  const ME_MEV=0.51099895;    // 電子質量 MeV/c²
  const LP=1.616255e-35;      // プランク長 m

  let rows='',unit='',note='';

  if(k==='natural'){
    unit='（自然単位：ħ=c=1, R=1）';
    note='質量の数値 = z<sub>nl</sub> そのもの';
    rows=ZNL.map((z,i)=>`<tr${i===0?' style="background:rgba(46,204,113,0.06);"':''}>
      <td>n=${i+1}</td>
      <td style="font-family:monospace;color:${BAR_COLS[i]}">${z.toFixed(6)}</td>
      <td style="font-family:monospace;">${ZREL[i].toFixed(4)}</td>
    </tr>`).join('');
  } else if(k==='electron'){
    const R=HBAR*ZNL[0]/(C*ME_MEV*MEV/C/C);
    unit=`電子質量スケール（R ≈ ${(HBAR*ZNL[0]/(C*ME_MEV*MEV/C/C)).toExponential(3)} m）`;
    note='n=1モードを電子質量 0.511 MeV/c² に合わせた場合';
    rows=ZNL.map((z,i)=>{
      const m_mev=z/ZNL[0]*ME_MEV;
      return`<tr${i===0?' style="background:rgba(46,204,113,0.06);"':''}>
        <td>n=${i+1}</td>
        <td style="font-family:monospace;color:${BAR_COLS[i]}">${m_mev.toFixed(4)} MeV/c²</td>
        <td style="font-family:monospace;">${ZREL[i].toFixed(4)}</td>
      </tr>`;
    }).join('');
  } else {
    const R=LP;
    const m1_kg=HBAR*ZNL[0]/(C*R);
    const m1_gev=m1_kg*C*C/(1e9*MEV);
    unit=`プランクスケール（R = ${LP.toExponential(3)} m）`;
    note='初期宇宙の超高エネルギー粒子に対応';
    rows=ZNL.map((z,i)=>{
      const m_gev=m1_gev*ZREL[i];
      return`<tr${i===0?' style="background:rgba(46,204,113,0.06);"':''}>
        <td>n=${i+1}</td>
        <td style="font-family:monospace;color:${BAR_COLS[i]}">${m_gev.toExponential(3)} GeV/c²</td>
        <td style="font-family:monospace;">${ZREL[i].toFixed(4)}</td>
      </tr>`;
    }).join('');
  }

  const el=document.getElementById('scaleTable');
  if(el) el.innerHTML=`
    <div style="font-size:10px;color:var(--acc);font-family:'Space Mono',monospace;margin-bottom:8px;">${unit}</div>
    <div style="font-size:11px;color:var(--muted);margin-bottom:10px;">${note}</div>
    <table>
      <tr><th>n</th><th>質量</th><th>相対質量</th></tr>
      ${rows}
    </table>`;
}

// ── 初期化 ──
window.onload=()=>{
  buildSphereSliders();drawSphere();
  buildFaceGrid();drawTetra();
  drawAllYlm();
};
</script>
</body>
</html>
